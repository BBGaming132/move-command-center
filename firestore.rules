rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isMoveMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/moves/n4CxhHlF8sszxyy9zdYt_I1B/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/moves/n4CxhHlF8sszxyy9zdYt_I1B/members/$(request.auth.uid)).data.active == true;
    }

    function memberUsername() {
      return get(/databases/$(database)/documents/moves/n4CxhHlF8sszxyy9zdYt_I1B/members/$(request.auth.uid)).data.username;
    }

    function isMasterItemId(itemId) {
      return itemId is string && itemId.matches('^[1-9][0-9]{0,2}$');
    }

    function isLegacyExtraItemId(itemId) {
      return itemId is string && itemId.matches('^EXTRA-[A-Z0-9]{8,24}$');
    }

    function isSequentialExtraItemId(itemId) {
      return itemId is string && itemId.matches('^(38[9]|39[0-9]|[4-9][0-9]{2}|[1-9][0-9]{3,5})$');
    }

    function isExtraItemId(itemId) {
      return isLegacyExtraItemId(itemId) || isSequentialExtraItemId(itemId);
    }

    function validOperationalItemId(itemId) {
      return isMasterItemId(itemId) || isExtraItemId(itemId);
    }

    function validReceivedPayload() {
      return request.resource.data.payload.keys().hasOnly([]);
    }

    function validReceiptVoidPayload() {
      return request.resource.data.payload.keys().hasOnly(['receiptId'])
        && request.resource.data.payload.receiptId is string
        && request.resource.data.payload.receiptId.size() > 0
        && request.resource.data.payload.receiptId.size() <= 100;
    }

    function validIssuePayload() {
      return request.resource.data.payload.keys().hasOnly(['note'])
        && request.resource.data.payload.note is string
        && request.resource.data.payload.note.size() > 0
        && request.resource.data.payload.note.size() <= 1000;
    }

    function validPlanPayload() {
      return request.resource.data.payload.keys().hasOnly([
        'assignedCrateId', 'destinationCode', 'destinationLabel', 'notes', 'keepOriginalRoom'
      ])
        && request.resource.data.payload.assignedCrateId is string
        && request.resource.data.payload.assignedCrateId.size() <= 40
        && request.resource.data.payload.destinationCode is string
        && request.resource.data.payload.destinationCode.size() <= 40
        && request.resource.data.payload.destinationLabel is string
        && request.resource.data.payload.destinationLabel.size() <= 120
        && request.resource.data.payload.notes is string
        && request.resource.data.payload.notes.size() <= 2000
        && (!request.resource.data.payload.keys().hasAny(['keepOriginalRoom'])
          || request.resource.data.payload.keepOriginalRoom is bool);
    }

    function validExtraItemPayload() {
      return request.resource.data.payload.keys().hasOnly([
        'description', 'comments', 'packType', 'observedArea',
        'assignedCrateId', 'destinationCode', 'destinationLabel', 'notes', 'tags'
      ])
        && request.resource.data.payload.description is string
        && request.resource.data.payload.description.size() > 0
        && request.resource.data.payload.description.size() <= 300
        && request.resource.data.payload.comments is string
        && request.resource.data.payload.comments.size() <= 1000
        && request.resource.data.payload.packType is string
        && request.resource.data.payload.packType.size() > 0
        && request.resource.data.payload.packType.size() <= 120
        && request.resource.data.payload.observedArea is string
        && request.resource.data.payload.observedArea.size() > 0
        && request.resource.data.payload.observedArea.size() <= 120
        && request.resource.data.payload.assignedCrateId is string
        && request.resource.data.payload.assignedCrateId.size() <= 40
        && request.resource.data.payload.destinationCode is string
        && request.resource.data.payload.destinationCode.size() <= 40
        && request.resource.data.payload.destinationLabel is string
        && request.resource.data.payload.destinationLabel.size() <= 120
        && request.resource.data.payload.notes is string
        && request.resource.data.payload.notes.size() <= 2000
        && request.resource.data.payload.tags is list
        && request.resource.data.payload.tags.size() <= 30;
    }


    function validExtraItemVoidPayload() {
      return request.resource.data.payload.keys().hasOnly(['reason'])
        && request.resource.data.payload.reason is string
        && request.resource.data.payload.reason.size() > 0
        && request.resource.data.payload.reason.size() <= 500;
    }

    function validSettingsPayload() {
      return request.resource.data.payload.keys().hasOnly(['hasCrateListing'])
        && request.resource.data.payload.hasCrateListing is bool;
    }

    function validDestinationsPayload() {
      return request.resource.data.payload.keys().hasOnly(['catalogJson'])
        && request.resource.data.payload.catalogJson is string
        && request.resource.data.payload.catalogJson.size() > 2
        && request.resource.data.payload.catalogJson.size() <= 12000;
    }

    function validSharedDestinationDocument() {
      return request.resource.data.keys().hasOnly([
        'catalogJson', 'updatedAt', 'updatedByUid', 'updatedByUsername'
      ])
        && request.resource.data.catalogJson is string
        && request.resource.data.catalogJson.size() > 2
        && request.resource.data.catalogJson.size() <= 12000
        && request.resource.data.updatedAt is int
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.updatedByUsername == memberUsername();
    }

    function validEvent(eventId) {
      return request.resource.data.keys().hasOnly([
        'id', 'moveId', 'type', 'itemId', 'deviceId', 'deviceName',
        'actorUid', 'actorUsername', 'clientAt', 'payload'
      ])
        && request.resource.data.id == eventId
        && request.resource.data.moveId == 'n4CxhHlF8sszxyy9zdYt_I1B'
        && request.resource.data.type in [
          'RECEIVED', 'PLAN_UPDATE', 'ISSUE', 'RECEIPT_VOID', 'ITEM_ADD', 'ITEM_EDIT', 'ITEM_VOID', 'SETTINGS_UPDATE', 'DESTINATIONS_UPDATE'
        ]
        && ((request.resource.data.type == 'SETTINGS_UPDATE' && request.resource.data.itemId == 'MOVE-SETTINGS')
          || (request.resource.data.type == 'DESTINATIONS_UPDATE' && request.resource.data.itemId == 'MOVE-DESTINATIONS')
          || (request.resource.data.type != 'SETTINGS_UPDATE'
            && request.resource.data.type != 'DESTINATIONS_UPDATE'
            && validOperationalItemId(request.resource.data.itemId)))
        && request.resource.data.deviceId is string
        && request.resource.data.deviceId.size() > 0
        && request.resource.data.deviceId.size() <= 100
        && request.resource.data.deviceName is string
        && request.resource.data.deviceName.size() > 0
        && request.resource.data.deviceName.size() <= 80
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorUsername == memberUsername()
        && request.resource.data.clientAt is int
        && request.resource.data.payload is map
        && (
          (request.resource.data.type == 'RECEIVED' && validReceivedPayload())
          || (request.resource.data.type == 'RECEIPT_VOID' && validReceiptVoidPayload())
          || (request.resource.data.type == 'ISSUE' && validIssuePayload())
          || (request.resource.data.type == 'PLAN_UPDATE' && validPlanPayload())
          || (request.resource.data.type == 'ITEM_ADD' && isExtraItemId(request.resource.data.itemId) && validExtraItemPayload())
          || (request.resource.data.type == 'ITEM_EDIT' && isExtraItemId(request.resource.data.itemId) && validExtraItemPayload())
          || (request.resource.data.type == 'ITEM_VOID' && isExtraItemId(request.resource.data.itemId) && validExtraItemVoidPayload())
          || (request.resource.data.type == 'SETTINGS_UPDATE' && request.resource.data.itemId == 'MOVE-SETTINGS' && validSettingsPayload())
          || (request.resource.data.type == 'DESTINATIONS_UPDATE' && request.resource.data.itemId == 'MOVE-DESTINATIONS' && validDestinationsPayload())
        );
    }

    match /moves/n4CxhHlF8sszxyy9zdYt_I1B/members/{uid} {
      allow read: if isMoveMember() && request.auth.uid == uid;
      allow write: if false;
    }

    match /moves/n4CxhHlF8sszxyy9zdYt_I1B/private/inventory {
      allow read: if isMoveMember();
      allow write: if false;
    }

    match /moves/n4CxhHlF8sszxyy9zdYt_I1B/shared/destinations {
      allow read: if isMoveMember();
      allow create, update: if isMoveMember() && validSharedDestinationDocument();
      allow delete: if false;
    }

    match /moves/n4CxhHlF8sszxyy9zdYt_I1B/events/{eventId} {
      allow read: if isMoveMember();
      allow create: if isMoveMember() && validEvent(eventId);
      allow update: if isMoveMember() && request.resource.data == resource.data;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
